                <div class="flex justify-between items-center">
                  <span class="text-xs font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('ticket.number') }}</span>
                  <span class="text-sm font-mono tracking-tight font-semibold">{{ ticket.ticketNumber }}</span>
                </div>
                @if(ticket.orderItem && ticket.orderItem.order)
                  <div class="flex justify-between items-center">
                    <span class="text-xs font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('ticket.order') }}</span>
                    <span class="text-sm font-mono tracking-tight">{{ ticket.orderItem.order.orderNumber }}</span>
                  </div>
                @endif
                <div class="flex justify-between items-center">
                  <span class="text-xs font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('ticket.status') }}</span>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                    @if(ticket.status === 'valid')
                      bg-success/10 text-success
                    @elseif(ticket.status === 'used')
                      bg-muted text-muted-foreground
                    @else
                      bg-destructive/10 text-destructive
                    @endif
                  ">
                    {{ ticket.status === 'valid' ? t('ticket.valid') : ticket.status }}
                  </span>

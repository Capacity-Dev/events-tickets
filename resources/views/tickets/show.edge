      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 sm:pb-20">
        <div class="max-w-lg mx-auto motion-safe:animate-[fadeInUp_0.5s_ease-out_0.1s_both]">
          <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
            @if(ticket.event.coverImageUrl)
              <img src="{{ ticket.event.coverImageUrl }}" alt="{{ ticket.event.title }}" class="w-full h-48 object-cover" />

@include('partials/header')

      <div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-12 motion-safe:animate-[fadeInUp_0.5s_ease-out]">
        <h1 class="font-heading text-[clamp(24px,3vw,32px)] mb-2">{{ t('payment.title') }}</h1>
        <p class="text-muted-foreground mb-6">{{ t('payment.subtitle') }} {{ order.orderNumber }}</p>

        <div class="bg-card border border-border rounded-xl p-5 sm:p-6 mb-6">

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 sm:pb-20 grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 lg:gap-12 items-start">
        <div class="motion-safe:animate-[fadeInUp_0.5s_ease-out_0.15s_both]">
          <div class="w-full aspect-[16/9] rounded-xl flex items-center justify-center font-heading text-5xl text-primary mb-8" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--accent)/10 100%);">
            EV

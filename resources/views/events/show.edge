<script>
function toggleBuyForm(id) {
  const form = document.getElementById('buy-form-' + id)
  const allForms = document.querySelectorAll('[id^="buy-form-"]')
  allForms.forEach(f => { if (f.id !== 'buy-form-' + id) f.classList.add('hidden') })
  form.classList.toggle('hidden')
}
</script>

@include('partials/footer')

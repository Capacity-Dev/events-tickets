          @if(event.venueName)
            <div class="bg-muted rounded-xl p-6 sm:p-8 mt-8">
              <div class="text-[11px] font-semibold uppercase tracking-[1px] text-muted-foreground mb-2">{{ t('event.venue') }}</div>
              <div class="font-semibold text-[15px]">{{ event.venueName }}</div>

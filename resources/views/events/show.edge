        <div class="lg:sticky lg:top-[88px] motion-safe:animate-[fadeInUp_0.5s_ease-out_0.2s_both]">
          <div class="bg-card border border-border rounded-xl p-6 sm:p-8 flex flex-col gap-6 shadow-sm">
            <div class="flex gap-4">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-muted-foreground" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="16" height="14" rx="2"/>
                <path d="M2 9h16"/><path d="M7 2v3"/><path d="M13 2v3"/>
              </svg>
              <div>
                <div class="text-[11px] font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('event.date_time') }}</div>
                <div class="text-sm leading-relaxed">
                  {{ event.startDate.toFormat('EEEE, MMMM d, yyyy') }}<br />
                  {{ event.startDate.toFormat('h:mm a') }}
                  @if(event.endDate)
                    — {{ event.endDate.toFormat('EEEE, MMMM d, yyyy · h:mm a') }}
                  @endif
                </div>

                <div class="flex flex-col gap-3">
                  @each(ticket in ticketTypes)
                    <div class="flex justify-between items-start gap-4 p-4 sm:p-5 border border-border rounded-[12px] hover:border-primary hover:bg-primary/5 transition-all duration-200 card-hover">
                      <div class="flex-1 min-w-0">

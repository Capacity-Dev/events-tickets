        @if(event.category)
          <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold tracking-[0.5px] bg-primary text-primary-foreground motion-safe:animate-[fadeInUp_0.5s_ease-out_0.1s_both]">

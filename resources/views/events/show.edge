                          </button>
                          <form id="buy-form-{{ ticket.id }}" action="/buy" method="POST" class="hidden mt-3 pt-3 border-t border-border space-y-3">
                            {{ csrfField() }}
                            <input type="hidden" name="ticketTypeId" value="{{ ticket.id }}" />
                            <input type="hidden" name="quantity" value="1" />
                            <div>
                              <label class="text-[11px] font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('event.name_label') }}</label>
                              <input type="text" name="name" required class="input-field min-h-10 mt-1" placeholder="{{ t('event.name_placeholder') }}" />
                            </div>
                            <div>
                              <label class="text-[11px] font-semibold uppercase tracking-[0.5px] text-muted-foreground">{{ t('event.phone_label') }}</label>
